# ===========================================
# EE-OpenGraph Environment Configuration
# Copy to .env and fill in values
# ===========================================

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=eeacc_dev_2026

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ETL Settings
ETL_BATCH_SIZE=500
ETL_RETRY_ATTEMPTS=3
ETL_RETRY_DELAY_SECONDS=5
ETL_LOG_LEVEL=INFO

# Data Source URLs
ARIREGISTER_API_URL=https://ariregister.rik.ee/est/api
ERJK_BASE_URL=https://www.erjk.ee
RIIGIHANKED_API_URL=https://riigihanked.riik.ee
LOBBYING_SOURCE_URL=https://www.korruptsioon.ee

# Rate Limiting (requests per second)
ARIREGISTER_RATE_LIMIT=2
ERJK_RATE_LIMIT=5
RIIGIHANKED_RATE_LIMIT=2
